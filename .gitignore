# Credenciais
.env
.env.local

# Cache de paginação Omie (raw da API) — pode ser regenerado via fetch-data
data/_cache/

# Dumps raw da API Omie (sensíveis, contém dados de cliente sem agregação)
# data.js (build artifact) é committado e contém apenas agregados
data/*.json
data/contas/
!data/.gitkeep

# Node
node_modules/

# OS
.DS_Store
Thumbs.db
*.log

# Editor
.vscode/
.idea/

# IMPORTANTE — NÃO ignorar build artifacts:
#   data.js, data-extras.js, app.bundle.js são committados (Docker COPY)
#   bi.config.js é committado (config do cliente sem credenciais)
#   report*.json são committados (relatórios IA pré-gerados)
